{
  "name": "@lf/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Last Fortress — Electron desktop shell (connects to the VDS server)",
  "main": "dist/main.cjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "npm run build:main && electron .",
    "build:main": "esbuild src/main.ts src/preload.ts --bundle --platform=node --format=cjs --external:electron --outdir=dist --out-extension:.js=.cjs",
    "dev:main": "npm run build:main -- --watch",
    "dev:client": "npm run -w @lf/client dev",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 dist/main.cjs && electron .",
    "dev": "npm run build:main && concurrently -k -n client,main,electron \"npm:dev:client\" \"npm:dev:main\" \"npm:dev:electron\"",
    "build:client": "cross-env VITE_SERVER_URL=212.180.120.69 npm run -w @lf/client build",
    "package": "npm run build:client && npm run build:main && electron-builder"
  },
  "build": {
    "appId": "com.swaffx.lastfortress",
    "productName": "Last Fortress",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "package.json"],
    "extraResources": [
      { "from": "../client/dist", "to": "client" }
    ],
    "win": { "target": ["nsis", "portable"] }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.0"
  }
}
